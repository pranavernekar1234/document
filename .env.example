# ─── DocuForge Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local and fill in the values for your deployment.

# ── Conversion Provider ────────────────────────────────────────────────────────
# Choose the backend conversion engine.
# Options: 'convertapi' | 'cloudconvert' | 'local'
# Default: 'convertapi'
CONVERSION_PROVIDER=convertapi

# ── ConvertAPI (Recommended for production) ────────────────────────────────────
# Sign up at https://www.convertapi.com — free tier includes 1500 conversions/month.
# Your account secret key (NOT the API key — use the secret from the dashboard).
CONVERTAPI_SECRET=RtJqcmyvQhxqw5zxDEz4MI3Oj33j196m

# ── CloudConvert (Alternative) ─────────────────────────────────────────────────
# Sign up at https://cloudconvert.com — pay-as-you-go pricing per conversion.
# Create an API key under Account → API Keys with 'tasks.read' and 'tasks.write' scopes.
CLOUDCONVERT_API_KEY=your_cloudconvert_api_key_here

# ── Local / Self-hosted Provider ───────────────────────────────────────────────
# Use this when running a Gotenberg container locally or in a private VPC.
# Example with Docker: docker run --rm -p 3001:3000 gotenberg/gotenberg:8
# CONVERSION_PROVIDER=local
# CONVERSION_ENDPOINT=http://localhost:3001

# ── Timeouts ───────────────────────────────────────────────────────────────────
# Maximum time in milliseconds to wait for a conversion to complete.
# Default: 120000 (2 minutes). Increase for large, complex documents.
CONVERSION_TIMEOUT_MS=120000

# ── Next.js ─────────────────────────────────────────────────────────────────────
# Set this in production for security headers and CORS.
NEXT_PUBLIC_APP_URL=http://localhost:3000
